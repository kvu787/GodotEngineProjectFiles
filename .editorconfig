root = true

[*]

charset = utf-8
end_of_line = crlf
trim_trailing_whitespace = true
insert_final_newline = true

[*.json]

indent_style = space
indent_size = 4

[*.csproj]

indent_style = space
indent_size = 4

[*.cs]

# Indents
indent_style = space
indent_size = 4

# Make all rules in all categories error
# https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/configuration-options#scope
dotnet_analyzer_diagnostic.severity = error

# IDE0003 and IDE0009: this and Me preferences
dotnet_style_qualification_for_field = true
dotnet_style_qualification_for_property = true
dotnet_style_qualification_for_event = true
dotnet_style_qualification_for_method = true

# IDE0055: C# formatting options, New-line options
csharp_new_line_before_open_brace = none
csharp_new_line_before_else = false
csharp_new_line_before_catch = false
csharp_new_line_before_finally = false
csharp_new_line_before_members_in_object_initializers = false
csharp_new_line_before_members_in_anonymous_types = false
csharp_new_line_between_query_expression_clauses = false

# IDE0055: C# formatting options, Using directive options
dotnet_sort_system_directives_first = false

# Disable IDE0130: Namespace does not match folder structure
dotnet_diagnostic.IDE0130.severity = none
dotnet_style_namespace_match_folder = false

# IDE0160, IDE0161: Namespace declaration preferences
csharp_style_namespace_declarations = file_scoped

# Disable: Add accessibility modifiers
dotnet_diagnostic.IDE0040.severity = none

# Disable: Null check can be simplified (if null check)
dotnet_diagnostic.IDE0270.severity = none

# Disable: Remove unused private member
dotnet_diagnostic.IDE0051.severity = none

# Disable: Convert to conditional expression
dotnet_diagnostic.IDE0045.severity = none

# Disable: Do not expose generic lists
dotnet_diagnostic.CA1002.severity = none

# Disable: Do not use insecure randomness
dotnet_diagnostic.CA5394.severity = none

# Disable: Specify IFormatProvider
dotnet_diagnostic.CA1305.severity = none

# Disable: Use collection expression for fluent
dotnet_diagnostic.IDE0305.severity = none

dotnet_diagnostic.IDE0004.severity = suggestion
dotnet_diagnostic.IDE0044.severity = suggestion
dotnet_diagnostic.IDE0046.severity = suggestion
dotnet_diagnostic.IDE0047.severity = suggestion
dotnet_diagnostic.IDE0048.severity = suggestion
dotnet_diagnostic.IDE0052.severity = suggestion
dotnet_diagnostic.IDE0059.severity = suggestion

dotnet_diagnostic.CA1823.severity = suggestion

dotnet_diagnostic.CS0219.severity = suggestion
dotnet_diagnostic.CS0649.severity = suggestion
dotnet_diagnostic.CS1591.severity = none
